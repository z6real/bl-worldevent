<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bizarre Lineage — Event Oracle</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Rajdhani:wght@300;400;500;600;700&display=swap');

  :root {
    --bg: #050810;
    --bg2: #0a0f1e;
    --panel: #0d1428;
    --border: #1a2a50;
    --accent: #3a7bd5;
    --accent2: #00c9ff;
    --gold: #f0a500;
    --gold2: #ffe066;
    --danger: #ff4d6d;
    --success: #00ffb3;
    --text: #c8d8f0;
    --muted: #4a6080;
    --glow: 0 0 20px rgba(58,123,213,0.4);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Rajdhani', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Starfield background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(200,216,240,0.6) 0%, transparent 100%),
      radial-gradient(1px 1px at 30% 60%, rgba(200,216,240,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 50% 10%, rgba(200,216,240,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 80%, rgba(200,216,240,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 40%, rgba(200,216,240,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 20% 85%, rgba(200,216,240,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 50%, rgba(200,216,240,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 15%, rgba(200,216,240,0.6) 0%, transparent 100%),
      radial-gradient(2px 2px at 45% 70%, rgba(240,165,0,0.4) 0%, transparent 100%),
      radial-gradient(2px 2px at 75% 30%, rgba(58,123,213,0.5) 0%, transparent 100%);
    pointer-events: none;
    z-index: 0;
  }

  /* Nebula gradient */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 20% 30%, rgba(58,123,213,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 50% 60% at 80% 70%, rgba(0,201,255,0.05) 0%, transparent 70%),
      radial-gradient(ellipse 40% 50% at 50% 50%, rgba(240,165,0,0.04) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .wrapper {
    position: relative;
    z-index: 1;
    max-width: 780px;
    margin: 0 auto;
    padding: 40px 20px 80px;
  }

  /* Header */
  header {
    text-align: center;
    margin-bottom: 48px;
  }

  .header-rune {
    font-size: 42px;
    margin-bottom: 8px;
    filter: drop-shadow(0 0 12px var(--gold));
    animation: pulse-rune 3s ease-in-out infinite;
  }

  @keyframes pulse-rune {
    0%, 100% { transform: scale(1); filter: drop-shadow(0 0 12px var(--gold)); }
    50% { transform: scale(1.08); filter: drop-shadow(0 0 22px var(--gold2)); }
  }

  h1 {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(18px, 4vw, 28px);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--gold2);
    text-shadow: 0 0 30px rgba(240,165,0,0.5), 0 0 60px rgba(240,165,0,0.2);
    margin-bottom: 10px;
  }

  .subtitle {
    font-size: 14px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 0 auto 36px;
    max-width: 420px;
  }
  .divider::before, .divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
  }
  .divider-gem {
    width: 8px; height: 8px;
    background: var(--gold);
    transform: rotate(45deg);
    box-shadow: 0 0 10px var(--gold);
    flex-shrink: 0;
  }

  /* Upload panel */
  .upload-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 32px;
    position: relative;
    overflow: hidden;
  }

  .upload-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), var(--accent2), var(--accent), transparent);
    opacity: 0.7;
  }

  .section-label {
    font-family: 'Rajdhani', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: 16px;
  }

  .drop-zone {
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 48px 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    background: rgba(58,123,213,0.03);
  }

  .drop-zone:hover, .drop-zone.drag-over {
    border-color: var(--accent);
    background: rgba(58,123,213,0.08);
    box-shadow: var(--glow);
  }

  .drop-zone input[type=file] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .drop-icon { font-size: 40px; margin-bottom: 12px; opacity: 0.7; }
  .drop-text { font-size: 16px; color: var(--text); margin-bottom: 6px; font-weight: 500; }
  .drop-hint { font-size: 13px; color: var(--muted); margin-bottom: 6px; }

  .paste-hint {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--accent2);
    background: rgba(0,201,255,0.08);
    border: 1px solid rgba(0,201,255,0.2);
    border-radius: 20px;
    padding: 4px 12px;
    letter-spacing: 0.1em;
    margin-top: 4px;
  }

  .paste-hint kbd {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 4px;
    padding: 1px 6px;
    font-family: monospace;
    font-size: 11px;
    color: #fff;
  }

  /* Paste flash animation */
  @keyframes paste-flash {
    0% { border-color: var(--accent2); box-shadow: 0 0 0 0 rgba(0,201,255,0.5); }
    50% { border-color: var(--accent2); box-shadow: 0 0 0 8px rgba(0,201,255,0); }
    100% { border-color: var(--border); box-shadow: none; }
  }
  .drop-zone.paste-flash {
    animation: paste-flash 0.6s ease-out;
  }

  /* OCR method badge */
  .method-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 10px;
    margin-left: 10px;
    vertical-align: middle;
  }
  .method-badge.ocr {
    background: rgba(0,255,179,0.1);
    border: 1px solid rgba(0,255,179,0.3);
    color: var(--success);
  }
  .method-badge.ai {
    background: rgba(58,123,213,0.1);
    border: 1px solid rgba(58,123,213,0.3);
    color: var(--accent2);
  }
  .method-badge.manual {
    background: rgba(240,165,0,0.1);
    border: 1px solid rgba(240,165,0,0.3);
    color: var(--gold);
  }

  /* Preview */
  #preview-wrap {
    display: none;
    margin-top: 20px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
    position: relative;
  }

  #preview-img {
    width: 100%;
    max-height: 240px;
    object-fit: contain;
    background: #000;
    display: block;
  }

  .preview-clear {
    position: absolute;
    top: 8px; right: 8px;
    background: rgba(0,0,0,0.7);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 50%;
    width: 28px; height: 28px;
    font-size: 16px;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .preview-clear:hover { background: var(--danger); border-color: var(--danger); }

  /* Manual input */
  .manual-section {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .or-divider {
    text-align: center;
    font-size: 12px;
    letter-spacing: 0.2em;
    color: var(--muted);
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .time-input-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .time-input-group {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 14px;
    flex: 1;
    min-width: 200px;
  }

  .time-input-group label {
    font-size: 12px;
    letter-spacing: 0.15em;
    color: var(--muted);
    white-space: nowrap;
    text-transform: uppercase;
  }

  .time-parts {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .time-parts input {
    background: transparent;
    border: none;
    color: var(--gold2);
    font-family: 'Rajdhani', sans-serif;
    font-size: 22px;
    font-weight: 700;
    width: 42px;
    text-align: center;
    outline: none;
  }

  .time-parts input::-webkit-inner-spin-button,
  .time-parts input::-webkit-outer-spin-button { -webkit-appearance: none; }

  .time-sep {
    color: var(--gold);
    font-size: 20px;
    font-weight: 700;
  }

  /* Analyze button */
  .btn-analyze {
    display: block;
    width: 100%;
    margin-top: 24px;
    padding: 16px;
    background: linear-gradient(135deg, #1a3a6e, #1e4a8a);
    border: 1px solid var(--accent);
    border-radius: 10px;
    color: var(--accent2);
    font-family: 'Rajdhani', sans-serif;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .btn-analyze::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(58,123,213,0.2), rgba(0,201,255,0.1));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .btn-analyze:hover::before { opacity: 1; }
  .btn-analyze:hover { box-shadow: 0 0 24px rgba(58,123,213,0.5); transform: translateY(-1px); }
  .btn-analyze:active { transform: translateY(0); }
  .btn-analyze:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  /* Processing state */
  .processing-indicator {
    display: none;
    text-align: center;
    padding: 32px;
    color: var(--accent2);
    font-size: 14px;
    letter-spacing: 0.2em;
  }

  .spin-rune {
    font-size: 32px;
    display: block;
    margin-bottom: 12px;
    animation: spin-slow 2s linear infinite;
  }

  @keyframes spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Results panel */
  #results {
    display: none;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    animation: reveal 0.5s ease;
  }

  @keyframes reveal {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .result-header {
    padding: 20px 28px;
    background: linear-gradient(135deg, rgba(58,123,213,0.12), rgba(0,201,255,0.05));
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .result-header::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
  }

  .detected-age {
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .detected-time {
    font-size: 36px;
    font-weight: 700;
    color: var(--gold2);
    text-shadow: 0 0 20px rgba(240,165,0,0.4);
    letter-spacing: 0.05em;
  }

  .next-event-section {
    padding: 28px;
  }

  .next-label {
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--accent2);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .next-event-card {
    background: linear-gradient(135deg, rgba(240,165,0,0.08), rgba(240,165,0,0.02));
    border: 1px solid rgba(240,165,0,0.3);
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }

  .next-event-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(240,165,0,0.5), transparent);
  }

  .event-icon { font-size: 36px; flex-shrink: 0; }

  .event-info { flex: 1; }

  .event-timestamp {
    font-size: 30px;
    font-weight: 700;
    color: var(--gold2);
    text-shadow: 0 0 15px rgba(240,165,0,0.5);
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 6px;
  }

  .event-countdown {
    font-size: 14px;
    color: var(--success);
    letter-spacing: 0.1em;
  }

  .event-index {
    font-size: 12px;
    color: var(--muted);
    text-align: right;
    flex-shrink: 0;
  }

  /* Upcoming list */
  .upcoming-label {
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .upcoming-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .upcoming-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 16px;
    background: rgba(255,255,255,0.02);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: all 0.2s;
  }

  .upcoming-item:hover {
    background: rgba(58,123,213,0.06);
    border-color: rgba(58,123,213,0.3);
  }

  .upcoming-num {
    font-size: 11px;
    color: var(--muted);
    width: 20px;
    text-align: center;
    flex-shrink: 0;
  }

  .upcoming-ts {
    font-size: 17px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.05em;
    flex: 1;
  }

  .upcoming-wait {
    font-size: 13px;
    color: var(--accent2);
    text-align: right;
  }

  /* Error */
  .error-msg {
    display: none;
    background: rgba(255,77,109,0.1);
    border: 1px solid rgba(255,77,109,0.3);
    border-radius: 10px;
    padding: 16px 20px;
    color: var(--danger);
    font-size: 14px;
    letter-spacing: 0.05em;
    margin-top: 16px;
  }

  /* API credit line */
  footer {
    text-align: center;
    margin-top: 48px;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.15em;
  }

  /* Tooltip for all timestamps */
  .all-events-toggle {
    text-align: center;
    margin-top: 20px;
  }

  .btn-toggle {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'Rajdhani', sans-serif;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-toggle:hover { border-color: var(--accent); color: var(--accent2); }

  .all-events-list {
    display: none;
    margin-top: 20px;
    padding: 20px;
    background: rgba(0,0,0,0.3);
    border: 1px solid var(--border);
    border-radius: 12px;
    max-height: 300px;
    overflow-y: auto;
  }

  .all-events-list::-webkit-scrollbar { width: 4px; }
  .all-events-list::-webkit-scrollbar-track { background: transparent; }
  .all-events-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .all-events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 6px;
  }

  .all-event-item {
    font-size: 13px;
    color: var(--muted);
    padding: 4px 8px;
    border-radius: 4px;
    text-align: center;
    letter-spacing: 0.05em;
    transition: color 0.2s;
  }

  .all-event-item.past { color: rgba(74,96,128,0.4); text-decoration: line-through; }
  .all-event-item.next { color: var(--gold2); font-weight: 700; background: rgba(240,165,0,0.08); }
  .all-event-item.future { color: var(--text); }
</style>
</head>
<body>
<div class="wrapper">
  <header>
    <div class="header-rune">⚔️</div>
    <h1>Event Oracle</h1>
    <div class="subtitle">Bizarre Lineage · World Event Tracker</div>
  </header>

  <div class="divider"><div class="divider-gem"></div></div>

  <div class="upload-panel">
    <div class="section-label">⬆ Upload Server Age Screenshot</div>
    <div class="drop-zone" id="dropZone">
      <input type="file" id="fileInput" accept="image/*">
      <div class="drop-icon">🖼️</div>
      <div class="drop-text">Drop screenshot here or click to browse</div>
      <div class="drop-hint">OCR reads the server age instantly</div>
      <div class="paste-hint">⚡ <kbd>Ctrl</kbd>+<kbd>V</kbd> to paste from clipboard</div>
    </div>

    <div id="preview-wrap">
      <img id="preview-img" src="" alt="Preview">
      <button class="preview-clear" id="clearBtn">✕</button>
    </div>

    <div id="error-msg" class="error-msg">⚠️ <span id="error-text"></span></div>

    <div class="manual-section">
      <div class="or-divider">— or enter server age manually —</div>
      <div class="time-input-row">
        <div class="time-input-group">
          <label>Server Age</label>
          <div class="time-parts">
            <input type="number" id="inputH" placeholder="0" min="0" max="99" title="Hours">
            <span class="time-sep">:</span>
            <input type="number" id="inputM" placeholder="00" min="0" max="59" title="Minutes">
            <span class="time-sep">:</span>
            <input type="number" id="inputS" placeholder="00" min="0" max="59" title="Seconds">
          </div>
        </div>
      </div>
    </div>

    <div class="processing-indicator" id="processing">
      <span class="spin-rune">✦</span>
      <span id="processing-text">Running OCR on your screenshot…</span>
    </div>

    <button class="btn-analyze" id="analyzeBtn">
      ⚡ Find Next World Event
    </button>
  </div>

  <div id="results">
    <div class="result-header">
      <div class="detected-age" id="detectedLabel">CURRENT SERVER AGE</div>
      <div class="detected-time" id="detectedTime">—</div>
    </div>
    <div class="next-event-section">
      <div class="next-label">⚡ Next World Event</div>
      <div class="next-event-card">
        <div class="event-icon">🌍</div>
        <div class="event-info">
          <div class="event-timestamp" id="nextTimestamp">—</div>
          <div class="event-countdown" id="nextCountdown">—</div>
        </div>
        <div class="event-index" id="nextIndex">—</div>
      </div>

      <div class="upcoming-label">Following Events</div>
      <div class="upcoming-list" id="upcomingList"></div>

      <div class="all-events-toggle">
        <button class="btn-toggle" id="toggleAll">Show All Event Timestamps</button>
      </div>
      <div class="all-events-list" id="allEventsList">
        <div class="all-events-grid" id="allEventsGrid"></div>
      </div>
    </div>
  </div>

  <footer>Powered by Claude AI Vision · Event data for Roblox Bizarre Lineage</footer>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/tesseract.js/5.0.4/tesseract.min.js"></script>
<script>
// All world event timestamps in seconds
const EVENT_TIMESTAMPS_RAW = [
  "0:20:00","0:42:01","1:04:02","1:26:03","1:48:04","2:10:05","2:32:06","2:54:07",
  "3:16:08","3:38:09","4:00:10","4:22:11","4:44:12","5:06:13","5:28:14","5:50:15",
  "6:12:16","6:34:17","6:56:18","7:18:19","7:40:20","8:02:21","8:24:22","8:46:23",
  "9:08:24","9:30:25","9:52:26","10:14:27","10:36:28","10:58:29","11:20:30","11:42:31",
  "12:04:32","12:26:33","12:48:34","13:10:35","13:32:36","13:54:37","14:16:38","14:38:39",
  "15:00:40","15:22:41","15:44:42","16:06:43","16:28:44","16:50:45","17:12:46","17:34:47",
  "17:56:48","18:18:49","18:40:50","19:02:51","19:24:52","19:46:53","20:08:54","20:30:55",
  "20:52:56","21:14:57","21:36:58","21:58:59","22:21:00","22:43:01","23:05:02","23:27:03",
  "23:49:04"
];

function parseTimestamp(ts) {
  const parts = ts.split(':').map(Number);
  return parts[0] * 3600 + parts[1] * 60 + parts[2];
}

function formatTimestamp(secs) {
  const h = Math.floor(secs / 3600);
  const m = Math.floor((secs % 3600) / 60);
  const s = secs % 60;
  return `${h}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}

function formatDiff(diffSecs) {
  if (diffSecs < 60) return `in ${diffSecs}s`;
  if (diffSecs < 3600) {
    const m = Math.floor(diffSecs / 60);
    const s = diffSecs % 60;
    return `in ${m}m ${s}s`;
  }
  const h = Math.floor(diffSecs / 3600);
  const m = Math.floor((diffSecs % 3600) / 60);
  const s = diffSecs % 60;
  return `in ${h}h ${m}m ${s}s`;
}

const EVENT_SECS = EVENT_TIMESTAMPS_RAW.map(parseTimestamp);

const MAX_SERVER_SECS = EVENT_SECS[EVENT_SECS.length - 1];

function findNextEvents(currentSecs, count = 5) {
  // Find all future events
  const future = [];
  for (let i = 0; i < EVENT_SECS.length; i++) {
    if (EVENT_SECS[i] > currentSecs) {
      future.push({ index: i + 1, timestamp: EVENT_TIMESTAMPS_RAW[i], secs: EVENT_SECS[i] });
    }
    if (future.length >= count) break;
  }
  return future;
}

// ---- UI State ----
let currentImageBase64 = null;
let currentImageDataUrl = null;

const fileInput = document.getElementById('fileInput');
const dropZone = document.getElementById('dropZone');
const previewWrap = document.getElementById('preview-wrap');
const previewImg = document.getElementById('preview-img');
const clearBtn = document.getElementById('clearBtn');
const analyzeBtn = document.getElementById('analyzeBtn');
const processing = document.getElementById('processing');
const processingText = document.getElementById('processing-text');
const results = document.getElementById('results');
const errorMsg = document.getElementById('error-msg');
const errorText = document.getElementById('error-text');

// Drag & drop
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  const file = e.dataTransfer.files[0];
  if (file) handleFile(file);
});

fileInput.addEventListener('change', () => {
  if (fileInput.files[0]) handleFile(fileInput.files[0]);
});

// ---- Ctrl+V Clipboard Paste ----
document.addEventListener('paste', async (e) => {
  const items = e.clipboardData?.items;
  if (!items) return;
  for (const item of items) {
    if (item.type.startsWith('image/')) {
      e.preventDefault();
      const file = item.getAsFile();
      if (file) {
        // Flash the drop zone to give feedback
        dropZone.classList.remove('paste-flash');
        void dropZone.offsetWidth; // reflow
        dropZone.classList.add('paste-flash');
        handleFile(file);
      }
      return;
    }
  }
});

clearBtn.addEventListener('click', () => {
  currentImageBase64 = null;
  currentImageDataUrl = null;
  previewWrap.style.display = 'none';
  previewImg.src = '';
  fileInput.value = '';
  hideError();
});

function handleFile(file) {
  if (!file.type.startsWith('image/')) { showError('Please upload an image file.'); return; }
  const reader = new FileReader();
  reader.onload = e => {
    currentImageDataUrl = e.target.result;
    currentImageBase64 = currentImageDataUrl.split(',')[1];
    previewImg.src = currentImageDataUrl;
    previewWrap.style.display = 'block';
    hideError();
  };
  reader.readAsDataURL(file);
}

// Manual input
const inputH = document.getElementById('inputH');
const inputM = document.getElementById('inputM');
const inputS = document.getElementById('inputS');

function pad(v, len=2) { return String(v).padStart(len,'0'); }

[inputM, inputS].forEach(inp => {
  inp.addEventListener('blur', () => { if (inp.value !== '') inp.value = pad(parseInt(inp.value)||0); });
  inp.addEventListener('input', () => { if (inp.value.length >= 2) { const next = inp.nextElementSibling?.nextElementSibling; if (next && next.tagName==='INPUT') next.focus(); } });
});

function getManualSecs() {
  const h = parseInt(inputH.value) || 0;
  const m = parseInt(inputM.value) || 0;
  const s = parseInt(inputS.value) || 0;
  return h * 3600 + m * 60 + s;
}

function showError(msg) {
  errorText.textContent = msg;
  errorMsg.style.display = 'block';
}
function hideError() {
  errorMsg.style.display = 'none';
}

// ---- OCR: extract timestamp from text ----
// Looks for patterns like 1:23:45 or 12:34:56 — the server age timer
function extractTimestampFromText(text) {
  // Normalize common OCR mistakes: O->0, l->1, I->1, S->5, B->8
  const cleaned = text
    .replace(/[Oo]/g, '0')
    .replace(/[lI]/g, '1')
    .replace(/[S]/g, '5')
    .replace(/[B]/g, '8');

  // Match H:MM:SS or HH:MM:SS patterns
  const matches = [...cleaned.matchAll(/\b(\d{1,2}):([0-5]\d):([0-5]\d)\b/g)];
  if (!matches.length) return null;

  // Prefer the one closest to a "server age" label if possible
  // Otherwise return the most plausible one (not a clock time - so < 24h and likely not exactly 12:xx:xx)
  // Return all and let caller pick
  return matches.map(m => ({
    hours: parseInt(m[1]),
    minutes: parseInt(m[2]),
    seconds: parseInt(m[3]),
    raw: m[0]
  }));
}

// ---- Tesseract OCR ----
async function runOCR(imageDataUrl) {
  processingText.textContent = 'Running OCR on screenshot…';
  try {
    // Use Tesseract with digits + colon whitelist for speed
    const result = await Tesseract.recognize(imageDataUrl, 'eng', {
      tessedit_char_whitelist: '0123456789:',
      psm: 11, // sparse text - finds scattered text
    });
    const text = result.data.text;
    const matches = extractTimestampFromText(text);
    if (matches && matches.length > 0) {
      // Pick the best match: largest value = longest-running server age (skip tiny times like 0:00:01)
      // But actually we want ANY valid one; prefer non-zero
      const best = matches.find(m => m.hours > 0 || m.minutes >= 10) || matches[0];
      return best;
    }
    return null;
  } catch (err) {
    console.warn('Tesseract OCR failed:', err);
    return null;
  }
}

// ---- Claude AI fallback ----
async function runClaudeAI(base64) {
  processingText.textContent = 'OCR inconclusive — asking Claude AI…';
  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-haiku-4-5-20251001",
      max_tokens: 200,
      messages: [{
        role: "user",
        content: [
          { type: "image", source: { type: "base64", media_type: "image/png", data: base64 } },
          { type: "text", text: `Find the server age timer in this Roblox Bizarre Lineage screenshot. It shows how long the server has been running (H:MM:SS format).
Return ONLY JSON, no other text:
{"found":true,"hours":0,"minutes":0,"seconds":0,"raw":"0:00:00"}
or {"found":false,"error":"reason"}` }
        ]
      }]
    })
  });
  const data = await response.json();
  const text = data.content?.find(b => b.type === 'text')?.text || '';
  const clean = text.replace(/```json|```/g, '').trim();
  return JSON.parse(clean);
}

// ---- Main Analyze ----
analyzeBtn.addEventListener('click', async () => {
  hideError();

  const hasManual = (inputH.value !== '' || inputM.value !== '' || inputS.value !== '');

  if (!currentImageBase64 && !hasManual) {
    showError('Upload a screenshot, paste one with Ctrl+V, or enter your server age manually.');
    return;
  }

  if (hasManual && !currentImageBase64) {
    const secs = getManualSecs();
    showResults(formatTimestamp(secs), secs, 'manual');
    return;
  }

  // Image path — try OCR first, then AI fallback
  analyzeBtn.disabled = true;
  processing.style.display = 'block';
  results.style.display = 'none';

  try {
    // 1. Try Tesseract OCR (fast, local)
    const ocrResult = await runOCR(currentImageDataUrl);

    if (ocrResult) {
      const secs = ocrResult.hours * 3600 + ocrResult.minutes * 60 + ocrResult.seconds;
      showResults(ocrResult.raw, secs, 'ocr');
      return;
    }

    // 2. OCR couldn't find it — fall back to Claude AI
    const aiResult = await runClaudeAI(currentImageBase64);
    if (!aiResult.found) throw new Error(aiResult.error || 'No server age timer found. Try entering manually.');
    const secs = (parseInt(aiResult.hours)||0)*3600 + (parseInt(aiResult.minutes)||0)*60 + (parseInt(aiResult.seconds)||0);
    showResults(aiResult.raw || formatTimestamp(secs), secs, 'ai');

  } catch (err) {
    showError(err.message || 'Something went wrong. Try entering the time manually.');
  } finally {
    analyzeBtn.disabled = false;
    processing.style.display = 'none';
  }
});

function showResults(rawTime, currentSecs, method) {
  const labelEl = document.getElementById('detectedLabel');
  const badgeClass = method === 'ocr' ? 'ocr' : method === 'ai' ? 'ai' : 'manual';
  const badgeLabel = method === 'ocr' ? '⚡ OCR' : method === 'ai' ? '🤖 AI' : '✏️ Manual';
  labelEl.innerHTML = `DETECTED SERVER AGE <span class="method-badge ${badgeClass}">${badgeLabel}</span>`;
  document.getElementById('detectedTime').textContent = rawTime;

  if (currentSecs > MAX_SERVER_SECS) {
    showError(`Server age ${rawTime} is beyond the last known event (${EVENT_TIMESTAMPS_RAW[EVENT_TIMESTAMPS_RAW.length-1]}).`);
    return;
  }

  const nextEvents = findNextEvents(currentSecs, 6);

  if (nextEvents.length === 0) {
    showError('No upcoming events found. Server may be past all scheduled events.');
    return;
  }

  const next = nextEvents[0];
  const diff = next.secs - currentSecs;

  document.getElementById('nextTimestamp').textContent = next.timestamp;
  document.getElementById('nextCountdown').textContent = `${formatDiff(diff)} (${diff}s away)`;
  document.getElementById('nextIndex').textContent = `Event #${next.index}\nof ${EVENT_SECS.length}`;

  const upcomingList = document.getElementById('upcomingList');
  upcomingList.innerHTML = '';
  for (let i = 1; i < nextEvents.length; i++) {
    const ev = nextEvents[i];
    const d = ev.secs - currentSecs;
    const item = document.createElement('div');
    item.className = 'upcoming-item';
    item.innerHTML = `
      <span class="upcoming-num">#${ev.index}</span>
      <span class="upcoming-ts">${ev.timestamp}</span>
      <span class="upcoming-wait">${formatDiff(d)}</span>
    `;
    upcomingList.appendChild(item);
  }

  const grid = document.getElementById('allEventsGrid');
  grid.innerHTML = '';
  EVENT_TIMESTAMPS_RAW.forEach((ts, i) => {
    const s = EVENT_SECS[i];
    const div = document.createElement('div');
    div.className = 'all-event-item';
    if (s < currentSecs) div.classList.add('past');
    else if (i === next.index - 1) div.classList.add('next');
    else div.classList.add('future');
    div.textContent = ts;
    grid.appendChild(div);
  });

  results.style.display = 'block';
  results.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// Toggle all events
const toggleAll = document.getElementById('toggleAll');
const allEventsList = document.getElementById('allEventsList');
toggleAll.addEventListener('click', () => {
  const visible = allEventsList.style.display === 'block';
  allEventsList.style.display = visible ? 'none' : 'block';
  toggleAll.textContent = visible ? 'Show All Event Timestamps' : 'Hide All Timestamps';
});
</script>
